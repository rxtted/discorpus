{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "newLine": "lf",
    "noEmitOnError": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@discorpus/asar": ["./packages/asar/src/index.ts"],
      "@discorpus/core": ["./packages/core/src/index.ts"],
      "@discorpus/db": ["./packages/db/src/index.ts"],
      "@discorpus/platform-windows": ["./packages/platform-windows/src/index.ts"],
      "@discorpus/runtime-cdp": ["./packages/runtime-cdp/src/index.ts"],
      "@discorpus/storage": ["./packages/storage/src/index.ts"],
      "@discorpus/targets-discord": ["./packages/targets-discord/src/index.ts"],
      "@discorpus/versioning": ["./packages/versioning/src/index.ts"]
    }
  }
}
